# .env.example — copy to .env.local and fill in real values
# Never commit .env.local or .env.production to git

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/memory_layer

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=local-dev-secret-change-this-before-production

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App Settings ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (production example):
# ALLOWED_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to false to use PostgreSQL instead of in-memory storage
DEMO_MODE=false