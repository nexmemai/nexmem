# .env.example — copy to .env.local and fill in real values.
# Never commit .env, .env.local, or .env.production.
#
# Every variable below is read by app/config.py via pydantic-settings.
# CI runs scripts/scan_secrets.py against this file and the rest of the
# tree, so do NOT replace the placeholders with real production values.

# ── Mode ─────────────────────────────────────────────────────────────────────
# When DEMO_MODE=true the app uses in-memory stores and does NOT require
# DATABASE_URL or REDIS_URL. The full test suite runs in this mode.
# Set to false in production.
DEMO_MODE=true

ENVIRONMENT=development           # development | staging | production
DEBUG=false                       # set to true ONLY for local debugging

# ── Database (required when DEMO_MODE=false) ─────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# For Supabase, use the pooler endpoint (port 6543), not the direct host.
# The asyncpg driver does not accept ?sslmode=...; SSL is enforced via
# connect_args in app/database.py.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/memory_layer

# ── Redis (required when DEMO_MODE=false) ────────────────────────────────────
# Used by:
#  - slowapi for IP-based rate limiting
#  - app/core/brute_force.py for login lockout (fails closed if missing)
#  - app/core/quotas.py for monthly write/read quotas (fails closed)
#  - Celery broker (background consolidation)
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 chars in production; validate_production() refuses
# to start otherwise.
SECRET_KEY=local-dev-secret-change-this-before-production

# Access-token TTL in hours. Short by default because there is no token
# revocation table yet (tracked as R-102 in BACKEND_RISKS.md).
ACCESS_TOKEN_EXPIRE_HOURS=4

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used for memory consolidation and RAG completions. Use sk-placeholder
# locally to keep AI features off without breaking startup.
OPENAI_API_KEY=sk-placeholder
OPENAI_LLM_MODEL=gpt-4o
CONSOLIDATION_LLM_MODEL=gpt-4o-mini

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON list or comma-separated string of allowed origins. Production must
# NOT use "*"; validate_production warns when it sees that.
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Observability ────────────────────────────────────────────────────────────
# Sentry is initialized only if SENTRY_DSN is set. Phase 2 ships with
# conservative trace sampling and PII scrubbing.
SENTRY_DSN=

# Optional: protect /metrics with a Bearer token. If unset, the endpoint
# returns 503 (off by default).
METRICS_SECRET_KEY=

# ── Consolidation scheduler ──────────────────────────────────────────────────
CONSOLIDATION_INTERVAL_MINUTES=30

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_API_URL=http://localhost:8000

# ── Quotas ───────────────────────────────────────────────────────────────────
# Monthly writes per tier; raised by app/core/quotas.py when needed.
FREE_MONTHLY_WRITES=1000
STARTER_MONTHLY_WRITES=10000
PRO_MONTHLY_WRITES=100000
ENTERPRISE_MONTHLY_WRITES=1000000

# Monthly reads per tier (Phase 2: enforced on /memory/context, /rag/chat).
FREE_MONTHLY_READS=10000
STARTER_MONTHLY_READS=100000
PRO_MONTHLY_READS=1000000
ENTERPRISE_MONTHLY_READS=10000000
